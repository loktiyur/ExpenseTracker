<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.expensetracker.controllers.ChartsController" >
    <padding>
        <Insets top="10" right="0" bottom="0" left="0"/>
    </padding>
    <VBox fx:id="сhartTabPane" styleClass="container" spacing="10" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="0" right="0" bottom="0" left="5"/>
        </padding>
        <HBox fx:id="сhartBox" spacing="10">
            <Button text="Bar Plot" onAction="#buildBarChart"/>
            <Button text="Line Plot" onAction="#buildLineChart"/>
            <Button text="PieChart" onAction="#buildPieChart"/>
        </HBox>
        <VBox styleClass="card" VBox.vgrow="ALWAYS">
            <StackPane fx:id="charts" VBox.vgrow="ALWAYS"/>
        </VBox>
    </VBox>

</VBox>
