pipeline{
    agent any
    stages{
        stage('Checkout'){
        steps{
            git branch: 'main', url: 'https://github.com/loktionov-data/ExpenseTracker.git'
        }
    }
        stage('Build'){
            steps{
                bat 'mvn clean package -DskipTests'
            }
        }
        stage('Test'){
            parallel{
                stage('Unit tests of ExpenseService'){
                    steps{
                        bat 'mvn -Dtest=ExpenseServiceTest test'
                    }
                }
                stage('Unit tests of FilterService'){
                    steps{
                        bat 'mvn -Dtest=FilterServiceTest test'
                    }
                }
            }
        }
        stage('Archive'){
            archiveArtifacts artifacts: '**/target/*.jar', fingerprint: true
        }
    }
    post{
                always{
                    junit '**/target/surefire-reports/*.xml'
                }
                success{
                    echo 'Build passed'
                    }
                failure{
                    echo 'Build failed!'
                    }
            }
}